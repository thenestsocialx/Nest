# Supabase — Settings → API in your dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App — used as the OAuth redirect base URL; set to your production domain in prod
NEXT_PUBLIC_APP_URL=

# Add these later
ANTHROPIC_API_KEY=

# ── Razorpay (plans & subscriptions) ──
RAZORPAY_KEY_ID=rzp_live_xxxx                        # from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_SECRET=xxxx                             # keep secret — server-side only
RAZORPAY_WEBHOOK_SECRET=xxxx                         # from Razorpay Dashboard → Webhooks → secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxx            # same as RAZORPAY_KEY_ID — safe to expose (public key)

# ── Zoho OAuth (for admin Ally scheduling integration) ──
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=${NEXT_PUBLIC_APP_URL}/api/v1/zoho/oauth/callback
ZOHO_API_BASE=   # Optional: override Zoho API base URL

# Additional services
RESEND_API_KEY=
DEEPGRAM_API_KEY=

# App mode toggle — "waitlist" shows modal + blocks /app/*; "live" = full app
NEXT_PUBLIC_APP_MODE=waitlist   # "waitlist" | "live"
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/meedbzzy

# ── Web Push / VAPID (generate once: node -e "require('web-push').generateVAPIDKeys()" ) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # public key — safe to expose
VAPID_PRIVATE_KEY=              # keep secret — server-side only
VAPID_SUBJECT=mailto:support@gonest.in